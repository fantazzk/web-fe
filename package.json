{
	"name": "web-fe",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "bun test",
		"test:watch": "bun test --watch"
	},
	"lint-staged": {
		"*.{js,ts,svelte}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,css,md,html}": [
			"prettier --write"
		]
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/bun": "^1.3.11",
		"@types/node": "^22.0.0",
		"eslint": "^10.0.3",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"html-to-image": "^1.11.13",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"msw": "^2.12.14",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.3.1"
	},
	"msw": {
		"workerDirectory": [
			"static"
		]
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.101.1"
	}
}
